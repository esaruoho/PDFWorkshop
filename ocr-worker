#!/usr/bin/env bash
# ocr-worker — Queue-based OCR daemon for CloudcityMacMini.
#
# Polls queue/pending/ for .job files, downloads PDFs, runs OCR via batch-ocr.mjs,
# and drops results into ~/work/comms/queue/ocr-results/ for Syncthing sync.
#
# Modeled after merlib-mirror's mirror-worker pattern:
#   - FIFO processing (oldest job first)
#   - Self-healing (recovers stuck jobs on startup)
#   - USR1 signal wakeup (from ocr-submit)
#   - Self-update (restarts if scripts change)
#   - PID file for signaling

set -euo pipefail

export PATH="/opt/homebrew/bin:$PATH"

REPO_DIR="$(cd "$(dirname "$0")" && pwd)"
PENDING_DIR="$REPO_DIR/queue/pending"
PRIORITY_DIR="$REPO_DIR/queue/priority"
PROCESSING_DIR="$REPO_DIR/queue/processing"
DONE_DIR="$REPO_DIR/queue/done"
FAILED_DIR="$REPO_DIR/queue/failed"
UPLOADS_DIR="$REPO_DIR/queue/uploads"
RESULTS_DIR="${HOME}/work/comms/queue/ocr-results"
INBOX_DIR="${HOME}/work/comms/queue/ocr-inbox"
HEARTBEAT_FILE="${HOME}/work/comms/queue/ocr-heartbeat.json"
OCR_SCRIPT="$REPO_DIR/batch-ocr.mjs"

# Off-network visibility — write a JSON heartbeat so the local Mac can tell
# whether we're idle, starting a job, or finished, via Syncthing.
# batch-ocr.mjs overwrites this with per-page progress while a job is running.
heartbeat() {
  local status="$1"
  local detail="${2:-}"
  local ts
  ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  printf '{\n  "ts": "%s",\n  "status": "%s",\n  "detail": "%s",\n  "worker_pid": %s\n}\n' \
    "$ts" "$status" "$detail" "$$" > "$HEARTBEAT_FILE" 2>/dev/null || true
}

POLL_IDLE=120    # seconds between checks when queue is empty
POLL_ACTIVE=10   # seconds between jobs
RUN_ONCE=false

for arg in "$@"; do
  case "$arg" in
    --once)    RUN_ONCE=true ;;
    --verbose) export VERBOSE=1 ;;
  esac
done

log()  { echo "[$(date +%H:%M:%S)] $*"; }
idle() { [[ "${VERBOSE:-}" == "1" ]] && log "$*" || true; }

# --- PID file ---
PIDFILE="$REPO_DIR/.ocr-worker.pid"
echo $$ > "$PIDFILE"

cleanup() { rm -f "$PIDFILE"; }
trap cleanup EXIT
trap 'log "Woken by signal"' USR1

# --- Self-update hash ---
WORKER_HASH=""

get_worker_hash() {
  md5 -q "$REPO_DIR/ocr-worker" "$REPO_DIR/start-ocr.sh" 2>/dev/null | md5 -q 2>/dev/null || echo "none"
}

check_self_update() {
  local new_hash
  new_hash="$(get_worker_hash)"
  if [[ -n "$WORKER_HASH" && "$new_hash" != "$WORKER_HASH" ]]; then
    log "Scripts updated — restarting worker..."
    exec "$REPO_DIR/ocr-worker" "$@"
  fi
  WORKER_HASH="$new_hash"
}

# --- Ensure directories exist ---
mkdir -p "$PRIORITY_DIR" "$PENDING_DIR" "$PROCESSING_DIR" "$DONE_DIR" "$FAILED_DIR" "$UPLOADS_DIR" "$RESULTS_DIR" "$INBOX_DIR"

# --- Recovery: move stuck processing jobs back to pending ---
recover_stuck() {
  local stuck
  stuck="$(ls "$PROCESSING_DIR"/*.job 2>/dev/null || true)"
  if [[ -n "$stuck" ]]; then
    log "Recovering stuck jobs from processing/"
    for f in $stuck; do
      mv "$f" "$PENDING_DIR/"
      log "  Recovered: $(basename "$f")"
    done
  fi
}

# --- Parse .job file ---
parse_job() {
  local job_file="$1"
  local key="$2"
  grep "^${key}:" "$job_file" 2>/dev/null | sed "s/^${key}:[[:space:]]*//" || echo ""
}

# --- Download PDF from URL ---
# NOTE: This function returns the path on stdout. All log messages go to stderr
# so they don't contaminate the captured return value from $().
download_pdf() {
  local url="$1"
  local output_dir="$2"

  # Handle file:// URLs (local files or SCP'd uploads)
  if [[ "$url" == file://* ]]; then
    local local_path="${url#file://}"
    if [[ -f "$local_path" ]]; then
      local basename
      basename="$(basename "$local_path")"
      cp "$local_path" "${output_dir}/${basename}"
      echo "${output_dir}/${basename}"
      return 0
    else
      log "  ERROR: Local file not found: $local_path" >&2
      return 1
    fi
  fi

  # Derive filename from URL
  local filename
  filename="$(basename "$url" | sed 's/[?#].*//')"

  # If no .pdf extension, add one
  local filename_lower
  filename_lower="$(echo "$filename" | tr '[:upper:]' '[:lower:]')"
  if [[ "$filename_lower" != *.pdf ]]; then
    filename="${filename}.pdf"
  fi

  local output_path="${output_dir}/${filename}"

  log "  Downloading: ${url}" >&2
  if curl -fsSL --max-time 300 --retry 3 -L -o "$output_path" "$url" 2>/dev/null; then
    # Verify it's actually a PDF (check magic bytes)
    local magic
    magic="$(head -c 5 "$output_path" 2>/dev/null || echo "")"
    if [[ "$magic" == "%PDF-" ]]; then
      # Return path on stdout (only this line!)
      echo "$output_path"
      return 0
    else
      log "  ERROR: Downloaded file is not a valid PDF (magic: ${magic})" >&2
      rm -f "$output_path"
      return 1
    fi
  else
    log "  ERROR: Download failed" >&2
    return 1
  fi
}

# --- Check OCR backend availability ---
check_ocr_backend() {
  # Test MLX
  if curl -sf --max-time 5 "http://localhost:8080/v1/models" >/dev/null 2>&1; then
    echo "mlx"
    return 0
  fi

  # Test Ollama (just check it's alive and has glm-ocr)
  if curl -sf --max-time 5 "http://localhost:11434/api/tags" 2>/dev/null | grep -q "glm-ocr"; then
    echo "ollama"
    return 0
  fi

  echo "none"
  return 1
}

# --- Process a single job ---
process_job() {
  local job_file="$1"
  local job_name
  job_name="$(basename "$job_file" .job)"

  log "Processing: ${job_name}"

  # Parse job fields
  local target engine priority ingest submitted_from
  target="$(parse_job "$job_file" "target")"
  engine="$(parse_job "$job_file" "engine")"
  priority="$(parse_job "$job_file" "priority")"
  ingest="$(parse_job "$job_file" "ingest")"
  submitted_from="$(parse_job "$job_file" "submitted_from")"

  engine="${engine:-glm}"
  ingest="${ingest:-false}"

  if [[ -z "$target" ]]; then
    log "  ERROR: No target URL in job file"
    mv "$job_file" "$FAILED_DIR/"
    return 1
  fi

  # Move to processing
  mv "$job_file" "$PROCESSING_DIR/"
  local proc_job="$PROCESSING_DIR/$(basename "$job_file")"

  # Create a temp working directory for this job
  local work_dir
  work_dir="$(mktemp -d "${REPO_DIR}/queue/.work_${job_name}_XXXX")"

  # Download PDF
  local pdf_path
  if ! pdf_path="$(download_pdf "$target" "$work_dir")"; then
    log "  FAILED: Could not download PDF"
    echo "error: download_failed" >> "$proc_job"
    mv "$proc_job" "$FAILED_DIR/"
    rm -rf "$work_dir"
    return 1
  fi

  log "  PDF: $(basename "$pdf_path")"

  # Create output directory
  local output_dir="${work_dir}/output"
  mkdir -p "$output_dir"

  # Run OCR
  log "  Running OCR (engine: ${engine})..."
  local ocr_exit=0
  if ! node "$OCR_SCRIPT" "$pdf_path" --output "$output_dir" 2>&1 | while IFS= read -r line; do
    echo "  [ocr] $line"
  done; then
    ocr_exit=1
  fi

  # Check if output was produced (even partial results are valuable)
  local result_count
  result_count="$(ls "$output_dir"/*_ocr.pdf "$output_dir"/*.txt 2>/dev/null | wc -l | tr -d ' ')"

  if [[ "$result_count" -eq 0 ]]; then
    log "  FAILED: No OCR output produced"
    echo "error: ocr_failed" >> "$proc_job"
    mv "$proc_job" "$FAILED_DIR/"
    rm -rf "$work_dir"
    return 1
  fi

  # Copy results to Syncthing output directory
  log "  Copying results to Syncthing (${RESULTS_DIR})..."
  mkdir -p "$RESULTS_DIR"
  cp "$output_dir"/* "$RESULTS_DIR/" 2>/dev/null || true

  # .txt is now generated by batch-ocr.mjs directly

  # Record completion metadata
  cat >> "$proc_job" <<EOF
completed: $(date -u +%Y-%m-%dT%H:%M:%SZ)
results: ${result_count} files
output_dir: ${RESULTS_DIR}
backend: ${engine}
EOF

  # Move job to done
  mv "$proc_job" "$DONE_DIR/"
  log "  DONE: ${result_count} files → ${RESULTS_DIR}/"

  # Cleanup working directory
  rm -rf "$work_dir"

  # If ingest requested, trigger fe-ingest.sh on the result
  if [[ "$ingest" == "true" ]]; then
    local fe_ingest="${HOME}/.claude/skills/free-energy/bin/fe-ingest.sh"
    if [[ -x "$fe_ingest" ]]; then
      log "  Auto-ingesting via fe-ingest.sh..."
      "$fe_ingest" "$RESULTS_DIR/${base_name}_ocr.pdf" 2>&1 | while IFS= read -r line; do
        echo "  [ingest] $line"
      done || log "  WARNING: Ingest had errors (non-fatal)"
    fi
  fi

  return 0
}

# --- Main loop ---
log "=== PDFWorkshop OCR Worker ==="
log "Queue:   ${PENDING_DIR}"
log "Inbox:   ${INBOX_DIR} (drop PDFs here)"
log "Results: ${RESULTS_DIR} (Syncthing)"
log "PID:     $$ (${PIDFILE})"
log ""

# Check OCR backend
backend="$(check_ocr_backend || true)"
if [[ "$backend" == "none" ]]; then
  log "WARNING: No OCR backend detected (MLX :8080 / Ollama :11434)"
  log "Jobs will fail until a backend is available."
else
  log "OCR backend: ${backend}"
fi

# Recover any stuck jobs
recover_stuck
WORKER_HASH="$(get_worker_hash)"

heartbeat "starting" "worker boot, backend=${backend}"

while true; do
  # --- Scan inbox for dropped PDFs (Syncthing drop folder) ---
  for inbox_pdf in "$INBOX_DIR"/*.pdf "$INBOX_DIR"/*.PDF; do
    [[ -f "$inbox_pdf" ]] || continue
    local_basename="$(basename "$inbox_pdf")"

    # Skip partially-synced files (still growing)
    local_size1="$(wc -c < "$inbox_pdf" 2>/dev/null | tr -d ' ')"
    sleep 2
    local_size2="$(wc -c < "$inbox_pdf" 2>/dev/null | tr -d ' ')"
    if [[ "$local_size1" != "$local_size2" ]]; then
      idle "Inbox: ${local_basename} still syncing (${local_size1} → ${local_size2})..."
      continue
    fi

    log "Inbox: found ${local_basename} ($(( local_size2 / 1024 / 1024 )) MB)"

    # Move to uploads and create a job
    mv "$inbox_pdf" "$UPLOADS_DIR/" 2>/dev/null || continue
    ts="$(date +%s)"
    safe_name="$(echo "$local_basename" | sed -E 's/[^a-zA-Z0-9._-]/_/g')"
    cat > "$PENDING_DIR/${ts}_${safe_name}.job" <<JOEOF
target: file://${UPLOADS_DIR}/${local_basename}
engine: glm
priority: normal
ingest: false
submitted: $(date -u +%Y-%m-%dT%H:%M:%SZ)
submitted_from: inbox
JOEOF
    log "  Created job from inbox: ${safe_name}"
  done

  # Find oldest pending job (FIFO)
  # Priority dir is checked first (LIFO for priority: newest bumped wins)
  local_job="$(ls -t "$PRIORITY_DIR"/*.job 2>/dev/null | head -1 || true)"
  if [[ -z "$local_job" ]]; then
    local_job="$(ls -t "$PENDING_DIR"/*.job 2>/dev/null | tail -1 || true)"
  fi

  if [[ -n "$local_job" ]]; then
    heartbeat "starting_job" "$(basename "$local_job" .job)"
    process_job "$local_job" || true
    check_self_update
    heartbeat "between_jobs" "last=$(basename "$local_job" .job)"

    if [[ "$RUN_ONCE" == true ]]; then
      log "Single-run mode — exiting."
      exit 0
    fi

    # Short pause between jobs
    sleep "$POLL_ACTIVE"
  else
    if [[ "$RUN_ONCE" == true ]]; then
      log "No pending jobs. Single-run mode — exiting."
      exit 0
    fi

    heartbeat "idle" "queue empty, polling ${POLL_IDLE}s"
    idle "Queue empty — sleeping ${POLL_IDLE}s..."
    sleep "$POLL_IDLE" &
    wait $! 2>/dev/null || true   # USR1 interrupts sleep
  fi
done
